DB_HOST=db
DB_PASSWORD=pass
DB_USER=postgres
DB_NAME=django_
DB_PORT=5432
# For RIKEN split deployment: set DB_HOST to compute server (private IP or SSH tunnel endpoint).

POSTGRES_PASSWORD=$DB_PASSWORD
POSTGRES_USER=$DB_USER
POSTGRES_DB=$DB_NAME

# --- Authentication (Keycloak OIDC) ---
# KEYCLOAK_URL is the URL the *backend* uses to fetch JWKS / metadata
# (typically the Docker-internal hostname).
KEYCLOAK_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=neuroworkflow
KEYCLOAK_CLIENT_ID=neuroworkflow-app
# Set KEYCLOAK_ISSUER when the URL the *browser* uses to reach Keycloak
# differs from KEYCLOAK_URL (split host). Tokens carry `iss` derived from
# the browser-facing URL, so the backend must validate against that.
#
# WARNING: KEYCLOAK_ISSUER must point at the SAME realm as KEYCLOAK_URL /
# KEYCLOAK_REALM. A typo or wrong-realm value will cause every login to
# fail at JWT verification (the JWKS signature check is realm-specific and
# the issuer string is checked exactly). Verify by logging in once after
# any change.
# KEYCLOAK_ISSUER=http://localhost:8080/auth/realms/neuroworkflow

DJANGO_SECRET_KEY='django-insecure-ps=r$krar9a52wp$n6x#qu64j@l68@ajqtps2&^oxyf*fx09^x'

PYTHONENV=/usr/bin/python3

# --- Deployment / reverse proxy ---
# Set BIND_HOST=0.0.0.0 in gui/.env for local dev (ports exposed to host).
# Default 127.0.0.1 binds to localhost only (safe behind nginx).
# BIND_HOST=0.0.0.0

# Extra ALLOWED_HOSTS (comma-separated). Always includes localhost/127.0.0.1.
# ALLOWED_HOSTS_EXTRA=your-server.riken.jp
# Set to true to allow all hosts (dev only):
# ALLOWED_HOSTS_ALL=true

# Extra CORS origins (comma-separated). Always includes localhost:5173.
# CORS_ALLOWED_ORIGINS_EXTRA=https://your-server.riken.jp
# Set to true to allow all origins (dev only):
# CORS_ALLOW_ALL=true

# Extra CSRF trusted origins (comma-separated).
# CSRF_TRUSTED_ORIGINS_EXTRA=https://your-server.riken.jp

# Optional: Local RAG / semantic search (in-repo rag/ or HyperRag) for parameter suggestions
# In-repo RAG: backend port 8006, frontend 3000. Auth = Bearer <username> (no login API).
# LOCAL_RAG_BASE_URL=http://localhost:8006
# LOCAL_RAG_USERNAME=john_doe
# LOCAL_RAG_PASSWORD=john123
# Leave LOGIN_ENDPOINT empty for in-repo RAG (uses username as Bearer). Set it only if your RAG has a token endpoint.
# LOCAL_RAG_LOGIN_ENDPOINT=
# LOCAL_RAG_USE_USERNAME_AS_BEARER=true
# LOCAL_RAG_QUERY_ENDPOINT=/query
# LOCAL_RAG_TIMEOUT=90   # /global_query can take 30–90s; increase if RAG is slow
# LOCAL_RAG_MAX_CHUNKS=10
# LOCAL_RAG_SOURCE_NAME=Local RAG

