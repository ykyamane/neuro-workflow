{
  "realm": "neuroworkflow",
  "enabled": true,
  "displayName": "NeuroWorkflow",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 86400,
  "ssoSessionMaxLifespan": 604800,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard NeuroWorkflow user",
        "composite": false
      },
      {
        "name": "admin",
        "description": "NeuroWorkflow administrator",
        "composite": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "neuroworkflow-app",
      "name": "NeuroWorkflow Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:5173/*",
        "https://*.riken.jp/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "https://*.riken.jp"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*##https://*.riken.jp/*",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "scopeMappings": [
    {
      "client": "neuroworkflow-app",
      "roles": ["user"]
    }
  ]
}
