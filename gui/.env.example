# gui/.env — Docker Compose environment
#
# Copy this file to .env and adjust for your environment.

# Path to the node definitions directory
NODES_DIR=/path/to/neuro-workflow/gui/workflow_backend/django-project/codes/nodes
HOST_PROJECT_PATH=/path/to/neuro-workflow/gui/workflow_backend/django-project

# Port binding: set to 0.0.0.0 for local dev, leave unset (defaults to
# 127.0.0.1) on the RIKEN server where nginx is the public entry point.
# BIND_HOST=0.0.0.0

# OpenAI key (for AI suggestions / browser chat)
# OPENAI_API_KEY=sk-...

# Anthropic key for the in-notebook Claude agent (Claude Agent SDK).
# This is the REAL key; it stays on the backend and powers the
# /api/chat/anthropic proxy. It is never exposed inside user kernels (the kernel
# authenticates to the proxy with JUPYTERHUB_API_TOKEN instead).
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override for the notebook agent (empty = CLI default).
# ANTHROPIC_MODEL=claude-opus-4-8

# JupyterHub
# JUPYTERHUB_API_TOKEN=dev-token-change-in-production

# Keycloak admin credentials (change for production!)
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=<strong-password>
# KEYCLOAK_DB_PASSWORD=<strong-password>
